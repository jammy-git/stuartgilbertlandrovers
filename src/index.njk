<section class="about" id="about">
  <div class="wrap">
    <div class="photo-frame">
      <svg class="regmark tl" aria-hidden="true" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1"><path d="M0 7 L 14 7 M7 0 L 7 14"/><circle cx="7" cy="7" r="3"/></svg>
      <svg class="regmark br" aria-hidden="true" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1"><path d="M0 7 L 14 7 M7 0 L 7 14"/><circle cx="7" cy="7" r="3"/></svg>
      <div class="photo" role="img" aria-label="Stuart and David Gilbert at the workshop"></div>
      <div class="photo-caption">Stuart and David Gilbert at the workshop, Orchards.</div>
    </div>
    <div>
      <div class="section-head" style="margin-bottom:0">
        <div class="tag">About us</div>
        <h2>Stuart and David Gilbert. A father and son workshop.</h2>
      </div>
      <p>Between us we have more than 75 years experience maintaining, repairing and servicing Land Rovers.</p>
      <p>Land Rovers have been at the heart of our working lives, and we take pride in keeping every vehicle performing exactly as it should &mdash; whether it's a family Discovery, a hard-working Defender, a cherished Range Rover, a Classic Range Rover or Series Land Rover.</p>
      <p>When you call, you will speak directly to <strong>Stuart or David</strong>. When you bring your vehicle in, it is one of us who will carry out the work. There are no receptionists, no service advisers and no middlemen. Just a father and son who care about doing the job properly.</p>
      <p class="sig">Stuart and David Gilbert, Orchards, Sittingbourne.</p>
    </div>
  </div>
</section>

<section class="services" id="services">
  <div class="wrap">
    <div class="section-head">
      <div class="tag">What we do</div>
      <h2>Everything a Land Rover needs, under one roof.</h2>
      <p>No frills, no upsell. Straightforward workshop care by two technicians who have spent their working lives on these vehicles.</p>
    </div>

    <div class="svc-grid">
      {%- for item in services.items | confirmed %}{% if loop.index <= 5 %}
      <article class="svc">
        <div class="num">{{ item.num }}</div>
        <h3>{{ item.title }}</h3>
        <p>{{ item.text }}</p>
      </article>
      {%- endif %}{% endfor %}
      <article class="svc cta">
        <div class="num">No. 06</div>
        <h3>Something else?</h3>
        <p>Not sure? Give us a ring. Happy to have a chat.</p>
        <a class="svc-call" href="tel:{{ site.phoneTel }}">{{ site.phoneDisplay }}</a>
      </article>
    </div>
    <p style="margin-top:28px"><a href="/services/" class="reviews-more">See all our services &rarr;</a></p>
  </div>
</section>

<section class="marques" id="marques">
  <div class="wrap">
    <div class="section-head">
      <div class="tag">Models</div>
      <h2>Every Land Rover, from Series I to the latest Defender.</h2>
    </div>
    {% include "partials/lineup.njk" %}
  </div>
</section>

<section class="recognised" aria-label="Partners and recognition">
  <div class="wrap">
    <div class="label">Recognised by</div>
    <div class="sub">Trusted by the Land Rover community and the parts trade</div>
    <div class="logos">
      <img src="/images/logos/britpart.png" alt="Britpart" width="336" height="50" loading="lazy">
      <img src="/images/logos/lro.png" alt="LRO - Land Rover Owner" class="tall" width="215" height="110" loading="lazy">
      <img src="/images/logos/landyzone.png" alt="Landyzone" width="412" height="100" loading="lazy">
      <img src="/images/logos/klrc.png" alt="Kent Land Rover Club" width="536" height="110" loading="lazy">
    </div>
  </div>
</section>

<section class="reviews" id="reviews" aria-label="Customer reviews">
  <div class="wrap">
    <div class="section-head">
      <div class="tag">Customer reviews</div>
      <h2>What our customers say.</h2>
      <div class="rating">
        <span class="stars" aria-hidden="true">★★★★★</span>
        <span class="number">{{ reviews.rating }}</span>
        <span class="count">{{ reviews.source }}</span>
      </div>
    </div>
    <div class="reviews-grid">
      {%- for r in reviews.items %}
      <article class="review">
        <div class="stars" aria-hidden="true">{% for _ in range(0, r.stars) %}★{% endfor %}</div>
        <p>"{{ r.text }}"</p>
        <div class="attribution"><span>{{ r.author }}</span></div>
      </article>
      {%- endfor %}
    </div>
    <a class="reviews-more" href="{{ reviews.googleUrl }}" target="_blank" rel="noopener">Read all reviews on Google &rarr;</a>
  </div>
</section>

<section class="quote" aria-label="From the workshop">
  <div class="wrap">
    <blockquote>
      <p>If it's got a green oval on the bonnet, we've probably had one in.</p>
      <cite>Stuart Gilbert</cite>
    </blockquote>
  </div>
</section>

<section class="area" id="area">
  <div class="contours" aria-hidden="true"></div>
  <div class="wrap">
    <div>
      <div class="section-head" style="margin-bottom:0">
        <div class="tag">Find us</div>
        <h2>A short drive from most of mid Kent.</h2>
        <p style="color:var(--hero-mute)">Based at Orchards, Sittingbourne. Land Rover owners regularly travel to us from across the county.</p>
      </div>
      <ul class="places">
        <li>Sittingbourne</li>
        <li>Maidstone</li>
        <li>Faversham</li>
        <li>Medway</li>
        <li>Sheppey</li>
        <li>Canterbury</li>
      </ul>
      <address>
        <b>{{ site.name }}</b>
        {{ site.address.street }}, {{ site.address.locality }}, {{ site.address.region }} {{ site.address.postcode }}<br>
        {{ site.hours.display }}
      </address>
    </div>
    {% include "partials/map.njk" %}
  </div>
</section>
