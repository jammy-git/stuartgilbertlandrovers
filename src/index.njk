  - /fonts/fraunces-latin-var.woff2
---
<section class="hero">
  <div class="scene" aria-hidden="true">
    <img src="/images/land_rover_hillside.svg" alt="" width="660" height="372">
  </div>
  <div class="wrap">
    <div class="eyebrow">Independent Land Rover specialist, Kent</div>
    <h1>Looking after Kent's Land Rovers for <em>over seventy-five years</em>.</h1>
    <p class="lede">A small, father and son workshop in Sittingbourne. Servicing, repairs and welding for Land Rover, Range Rover, Discovery, Defender, &amp; Series owners across Kent.</p>
  </div>
</section>

